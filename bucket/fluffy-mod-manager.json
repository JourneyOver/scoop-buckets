{
    "version": "2026.05.30.1038",
    "description": "MOD MANAGER & MOD DOWNLOADER & TRAINER & MORE",
    "homepage": "https://www.fluffyquack.com/",
    "license": "Unknown",
    "url": "https://fluffyquack.com/tools/modmanager.zip",
    "hash": "3cd2b04b55755c228bd602bde952b46d037a2d014db8da60bd296fb2b408a630",
    "bin": "Modmanager.exe",
    "shortcuts": [
        [
            "Modmanager.exe",
            "Fluffy Mod Manager"
        ]
    ],
    "persist": [
        "Games",
        "Data"
    ],
    "checkver": {
        "re": "(?<version>[\\d.]+)",
        "script": [
            "try {",
            "    $url = 'https://fluffyquack.com/tools/'",
            "    $response = Invoke-WebRequest -Uri $url -UseBasicParsing",
            "    $content = $response.Content",
            "    # Find the specific line for modmanager.zip",
            "    $line = ($content -split '\\r?\\n' | Where-Object { $_ -match 'href=\"modmanager\\.zip\"' } | Select-Object -First 1)",
            "    # Extract the 'Last modified' timestamp",
            "    if ($line -match '(?<date>\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2})') {",
            "        $timestamp = $Matches['date']",
            "        # Format as yyyy.MM.dd.HHmm for Scoop versioning",
            "        $version = [DateTime]::ParseExact($timestamp, 'yyyy-MM-dd HH:mm', $null).ToString('yyyy.MM.dd.HHmm')",
            "        Write-Output $version",
            "    }",
            "} catch {",
            "    Write-Error $_.Exception.Message",
            "}"
        ]
    },
    "autoupdate": {
        "url": "https://fluffyquack.com/tools/modmanager.zip"
    }
}
