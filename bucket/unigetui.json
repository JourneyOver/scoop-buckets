{
    "version": "2026.1.10",
    "description": "UniGetUI: The Graphical Interface for your package managers. Could be terribly described as a package manager manager to manage your package managers",
    "homepage": "https://www.marticliment.com/unigetui/",
    "license": {
        "identifier": "MIT",
        "url": "https://raw.githubusercontent.com/Devolutions/UniGetUI/main/LICENSE"
    },
    "url": "https://github.com/Devolutions/UniGetUI/releases/download/v2026.1.10/UniGetUI.Installer.exe",
    "hash": "364434300ae50026ce11559b571761a1ef564bbb69fcb160c134e9d7f980c229",
    "pre_install": [
        "$filePath = Join-Path $dir 'ForceUniGetUIPortable'",
        "if (-not (Test-Path -Path $filePath -PathType Leaf)) {",
        "    New-Item -Path $filePath -ItemType File | Out-Null",
        "}"
    ],
    "shortcuts": [
        [
            "UniGetUI.exe",
            "UniGetUI"
        ]
    ],
    "persist": [
        "ForceUniGetUIPortable",
        "Settings"
    ],
    "innosetup": true,
    "checkver": {
        "url": "https://api.github.com/repos/Devolutions/UniGetUI/releases",
        "jp": "$..tag_name",
        "re": "(?!v)([\\d.]+(?:-[\\da-zA-Z.-]+)?)"
    },
    "autoupdate": {
        "url": "https://github.com/Devolutions/UniGetUI/releases/download/v$version/UniGetUI.Installer.exe"
    }
}
